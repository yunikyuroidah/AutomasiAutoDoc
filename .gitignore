# Local Python environment
.venv/

# Generated exports
storage/exports/

# Temporary generated artifacts
tmp/gen_dp/
tmp_docx/
tmp/*.zip

# Common local logs
*.log

# Environment and secret files
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub

# Keep template folder in repo but exclude its sensitive contents
template/**
!template/.gitkeep

# Never commit office source files
*.doc
*.docx
*.xls
*.xlsx
*.xlsm

# Temporary text dumps
tmp/*.txt
